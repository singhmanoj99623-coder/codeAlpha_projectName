const express = require('express');
const cors = require('cors');
const fs = require('fs');
const path = require('path');
const app = express();

app.use(cors());
app.use(express.json());
app.use(express.static('public')); // serve frontend

const PRODUCTS_FILE = 'products.json';
const ORDERS_FILE = 'orders.json';

// Seed products if file doesn't exist
if (!fs.existsSync(PRODUCTS_FILE)) {
  const seedProducts = [
    { id: 1, name: "Wireless Headphones", price: 89.99, image: "https://picsum.photos/400/400?random=1", desc: "Bluetooth 5.0, 30hr battery, noise cancelling" },
    { id: 2, name: "Smart Watch", price: 199.99, image: "https://picsum.photos/400/400?random=2", desc: "Heart rate, GPS, water resistant 50m" },
    { id: 3, name: "4K Webcam", price: 129.99, image: "https://picsum.photos/400/400?random=3", desc: "Auto-focus, dual mic, privacy shutter" },
    { id: 4, name: "Mechanical Keyboard", price: 149.99, image: "https://picsum.photos/400/400?random=4", desc: "Hot-swappable, RGB, PBT keycaps" },
    { id: 5, name: "Portable SSD 1TB", price: 99.99, image: "https://picsum.photos/400/400?random=5", desc: "1050MB/s, USB-C, shock resistant" },
    { id: 6, name: "Desk Lamp", price: 39.99, image: "https://picsum.photos/400/400?random=6", desc: "LED, touch dimmer, USB charging port" }
  ];
  fs.writeFileSync(PRODUCTS_FILE, JSON.stringify(seedProducts));
}
if (!fs.existsSync(ORDERS_FILE)) fs.writeFileSync(ORDERS_FILE, JSON.stringify([]));

// GET all products
app.get('/api/products', (req, res) => {
  const products = JSON.parse(fs.readFileSync(PRODUCTS_FILE));
  res.json(products);
});

// GET single product
app.get('/api/products/:id', (req, res) => {
  const products = JSON.parse(fs.readFileSync(PRODUCTS_FILE));
  const product = products.find(p => p.id == req.params.id);
  product ? res.json(product) : res.status(404).json({ error: 'Product not found' });
});

// POST create order
app.post('/api/orders', (req, res) => {
  const { items, total, customer } = req.body;
  if (!items || !total || !customer?.name || !customer?.email) {
    return res.status(400).json({ error: 'Missing required fields' });
  }
  
  const orders = JSON.parse(fs.readFileSync(ORDERS_FILE));
  const order = {
    id: Date.now().toString(),
    items,
    total,
    customer,
    status: 'pending',
    createdAt: new Date().toISOString()
  };
  orders.push(order);
  fs.writeFileSync(ORDERS_FILE, JSON.stringify(orders, null, 2));
  res.json({ success: true, orderId: order.id });
});

app.listen(3000, () => console.log('Server running on http://localhost:3000'));
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SimpleShop</title>
<style>
